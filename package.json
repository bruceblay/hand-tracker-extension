{
  "name": "hand-tracker-extension",
  "displayName": "Hand Tracker",
  "version": "0.0.1",
  "description": "Webcam hand tracking with pinch-to-click on any web page",
  "author": "Bruce Blay <bruceblay@gmail.com>",
  "scripts": {
    "dev": "plasmo dev && node scripts/copy-mediapipe.js",
    "build": "plasmo build && node scripts/copy-mediapipe.js",
    "copy-mediapipe": "node scripts/copy-mediapipe.js",
    "package": "plasmo package"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "offscreen",
      "activeTab",
      "scripting",
      "storage",
      "tabs"
    ],
    "commands": {
      "toggle-hand-control": {
        "suggested_key": {
          "default": "Ctrl+Shift+H",
          "mac": "Command+Shift+H"
        },
        "description": "Toggle hand control on the active tab"
      }
    },
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    }
  }
}
